{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-commissions.xml",
    "style": "xml",
    "headerText": "COMMISSIONS BUNDLE — commission ground truth, compute helpers, grid engine, course engine, credit matrix, payment flows. Read docs/commission-spec.md FIRST: spec wins over code or memory.",
    "fileSummary": true,
    "directoryStructure": true,
    "topFilesLength": 15
  },
  "include": [
    "docs/commission-spec.md",
    "app/grid.py",
    "app/course_engine.py",
    "app/credit_matrix.py",
    "app/payment.py",
    "app/crypto_payments.py",
    "app/crud.py",
    "app/models.py",
    "app/helpers/**",
    "frontend/src/pages/CommandCentre.jsx",
    "frontend/src/pages/Leaderboard*.jsx",
    "frontend/src/pages/Grid.jsx",
    "frontend/src/pages/Earnings*.jsx",
    "frontend/src/pages/Withdraw*.jsx",
    "frontend/src/pages/ActivateTier.jsx",
    "frontend/src/pages/CreditMatrix.jsx"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "static/app/**",
      "**/*.backup",
      "**/*.bak"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
