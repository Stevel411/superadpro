{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-map.xml",
    "style": "xml",
    "headerText": "REPO MAP (COMPRESSED, BACKEND ONLY) — Python signatures only, no function bodies. Use to locate WHERE things live in app/, then pull specific files. Frontend pages omitted (too many).",
    "fileSummary": true,
    "directoryStructure": true,
    "compress": true,
    "topFilesLength": 30
  },
  "include": [
    "app/**",
    "docs/commission-spec.md",
    "requirements.txt"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "app/**/*.backup",
      "app/**/*.bak",
      "app/templates/**",
      "__pycache__/**",
      "*.pyc"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
