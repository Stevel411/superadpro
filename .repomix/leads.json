{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-leads.xml",
    "style": "xml",
    "headerText": "LEADS BUNDLE — Lead Finder (Outscraper), MyLeads CRM, Brevo autoresponder. Brevo sender: noreply@superadpro.com via Zoho Mail.",
    "fileSummary": true,
    "directoryStructure": true,
    "topFilesLength": 15
  },
  "include": [
    "app/lead_finder.py",
    "app/brevo_service.py",
    "app/email_utils.py",
    "frontend/src/pages/LeadFinder.jsx",
    "frontend/src/pages/MyLeads*.jsx",
    "frontend/src/pages/ProSeller.jsx"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": ["**/*.backup", "**/*.bak"]
  },
  "security": {"enableSecurityCheck": true}
}
