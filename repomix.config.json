{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "headerText": "SuperAdPro codebase bundle. FastAPI/Python backend + React/Vite frontend + PostgreSQL. Commission ground truth lives in docs/commission-spec.md — that spec wins over code or memory.",
    "fileSummary": true,
    "directoryStructure": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": false,
    "topFilesLength": 20
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "static/app/**",
      "static/downloads/**",
      "**/*.backup",
      "**/*.bak",
      "**/*.min.js",
      "**/*.min.css",
      "**/*.map",
      "**/*.lock",
      "**/package-lock.json",
      "frontend/dist/**",
      "frontend/node_modules/**",
      "frontend/src/i18n/locales/**",
      "data/**",
      "mockups/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.pyc",
      "repomix-output*.xml",
      "repomix-output*.md"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
